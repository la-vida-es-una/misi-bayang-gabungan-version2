# Ollama OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# MCP server (same process, different mount path)
MCP_BASE_URL=http://localhost:8000/mcp

# World simulation tuning
WORLD_TICK_INTERVAL=0.5 # seconds
AGENT_TICK_INTERVAL=2.0 # seconds
BATTERY_LOW_THRESHOLD=25.0
