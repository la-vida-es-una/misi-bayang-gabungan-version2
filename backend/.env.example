# Ollama OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# MCP server (same process, different mount path)
MCP_BASE_URL=http://localhost:8000/mcp/mcp

# World simulation tuning
WORLD_TICK_INTERVAL=1.0 # seconds (synced with agent tick)
AGENT_TICK_INTERVAL=1.0 # seconds

# Multi-agent configuration
MULTI_AGENT_ENABLED=true  # Use supervisor + worker architecture
SUPERVISOR_TICK_INTERVAL=2.0  # seconds between supervisor reasoning cycles

BATTERY_LOW_THRESHOLD=25.0

# Logging: DEBUG | INFO (default) | WARNING | ERROR
LOG_LEVEL=INFO
